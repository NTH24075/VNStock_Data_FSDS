{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "raw_ohlcv_daily.v2",
  "description": "OHLCV daily data contract — partitions on/after 2025-07-01",
  "type": "object",
  "required": ["ticker_id", "trade_date", "open", "high", "low", "close", "volume", "value", "foreign_room"],
  "properties": {
    "ticker_id":   { "type": "string" },
    "trade_date":  { "type": "string", "format": "date" },
    "open":        { "type": "number", "exclusiveMinimum": 0 },
    "high":        { "type": "number", "exclusiveMinimum": 0 },
    "low":         { "type": "number", "exclusiveMinimum": 0 },
    "close":       { "type": "number", "exclusiveMinimum": 0 },
    "volume":      { "type": "integer", "minimum": 0 },
    "value":       { "type": "number", "minimum": 0 },
    "foreign_room":{ "type": "number", "minimum": 0 }
  }
}
